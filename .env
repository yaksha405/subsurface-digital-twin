# ===================================================================
# 数据源配置 — 后端就绪后只需修改这里
# ===================================================================

# mock = 使用内置模拟数据 | live = 对接真实后端API
VITE_API_MODE=mock

# 后端 API 基础地址（live 模式下生效）
# 你的后端只需实现以下接口：
#   GET  /scene/nodes        → SceneNode[]
#   GET  /scene/geometry     → FlatGeometryData (预计算点云)
#   GET  /scene/stats        → SceneStats
#   GET  /pois               → POI[]
#   GET  /ai/quick-commands  → QuickCommand[]
#   POST /ai/chat            → SSE 流式 AI 响应
VITE_API_BASE_URL=/api

# WebSocket 地址（实时传感器推送，可选）
VITE_WS_URL=ws://localhost:8080/ws
